<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.young.mapper.SysUserMapper">

    <select id="selectByUsername" resultType="com.young.pojo.SysUser">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (username, password, role, create_time, update_time)
        VALUES (#{username}, #{password}, #{role}, NOW(), NOW())
    </insert>

</mapper>
